    "type-check": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@nogg-aholic/nrpc": "latest"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  }
}