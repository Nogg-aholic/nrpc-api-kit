{
  "name": "@nogg-aholic/nrpc-api-kit",
  "version": "0.1.0",
  "description": "Shared helpers for nRPC 0.4.0 service transport and code generation",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
